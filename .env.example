# ── Bot ─────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here
DB_PATH=deckbot.db

# ── API (deckbot-api.service / `python -m deckbot api`) ──────────────────────
# No extra env vars needed; the API shares DB_PATH above.
# Bind address and port are passed as --host / --port CLI flags.

# ── Node (`python -m deckbot node`) ─────────────────────────────────────────
NODE_API_ENDPOINT=http://127.0.0.1:8000   # URL of the API server
NODE_API_KEY=your_node_api_key_here       # Key shown once by /deckbot node-create
NODE_MAX_THREADS=1                        # Concurrent MYSTRAN jobs
NODE_BUILD_CACHE_DIR=/tmp/deckbot_node/cache   # Cached git clones + binaries
NODE_WORK_BASE_DIR=/tmp/deckbot_node/work      # Per-run temp directories
NODE_BUILD_TYPE=RelWithDebInfo            # CMake build type
NODE_POLL_INTERVAL=10.0                   # Seconds between job polls
NODE_KEEPALIVE_INTERVAL=60.0             # Seconds between keepalive pings
