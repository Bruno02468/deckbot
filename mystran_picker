#!/bin/bash
# mystran_picker: build/run mystran with a specific version, and keep cache.
# usage: mystran_picker <version specification> [deck]
#   - <version specification>: required. can be one of:
#     1. v<tag>, e.g. v17.0.0, v15.2.1
#     2. c<commit hash>, e.g. cbb30cea
#     3. b<branch>, e.g. bmain (latest commit in branch)
#   - [deck]: optional.
#     - if present, it runs mystran with that deck.
#     - if absent, this script outputs the path to the binary to stdout.
#       - that's to enable commands like gdb $(mystran_picker v17.0.0) deck.dat
#   - builds are RelWithDebInfo by default. if you want another, set the env var
#     BUILD_TYPE to something else like "Debug".
#   - I recommend you change BINARIES_DIRECTORY to a more permanent location.
#     preferably, something in your $PATH.
# this is version #1 of this script, made in 2026-01-16.
# consider all of this in the public domain. no rights reserved. by bruno02468.

# end-user configuration
BINARIES_DIRECTORY="/home/bruno/Scripts/mystran_versions"
REPOSITORY_DIR="/tmp/mystran_picker_repo"
LOG_FILE="/tmp/mystran_picker.log"
REPOSITORY_URL="https://github.com/MYSTRANsolver/MYSTRAN.git"
CONFIGURE_COMMAND="cmake -G 'Unix Makefiles' -DCMAKE_BUILD_TYPE=\$BUILD_TYPE \
-Denable_internal_blaslib=yes ."

# Set default build type if not in environment
BUILD_TYPE="${BUILD_TYPE:-RelWithDebInfo}"

# Determine number of parallel jobs
if command -v nproc >/dev/null 2>&1; then
  JOBS=$(($(nproc) + 1))
else
  JOBS=5
fi
BUILD_COMMAND="cmake --build . -j${JOBS}"

# Logging function
log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"
}

# Log session start
log_session_start() {
  echo "" >> "$LOG_FILE"
  log "========================================"
  log "Session started: $0 $*"
  log "BUILD_TYPE: $BUILD_TYPE"
  log "JOBS: $JOBS"
}

# Log session end
log_session_end() {
  log "Session ended: $1"
  log "========================================"
}

# Error handling: print to stderr and output /usr/bin/false
error_exit() {
  log "ERROR: $1"
  echo "$1" >&2
  log_session_end "FAILED"
  echo "/usr/bin/false"
  exit 0
}

# Convert BUILD_TYPE to abbreviation
get_build_type_abbrev() {
  case "$BUILD_TYPE" in
    Debug)
      echo "dbg"
      ;;
    Profiling)
      echo "prof"
      ;;
    Deterministic)
      echo "det"
      ;;
    Release|RelWithDebInfo)
      echo "rel"
      ;;
    *)
      echo "rel"
      ;;
  esac
}

# Parse arguments and determine mode
parse_arguments() {
  if [ $# -lt 1 ] || [ $# -gt 2 ]; then
    error_exit "Usage: $0 <version-spec> [input-file]"
  fi

  VERSION_SPEC="$1"
  INPUT_FILE="$2"

  # Parse version type
  case "${VERSION_SPEC:0:1}" in
    c)
      VERSION_TYPE="commit"
      VERSION_VALUE="${VERSION_SPEC:1}"
      ;;
    v)
      VERSION_TYPE="tag"
      VERSION_VALUE="${VERSION_SPEC:1}"
      ;;
    b)
      VERSION_TYPE="branch"
      VERSION_VALUE="${VERSION_SPEC:1}"
      ;;
    *)
      error_exit "Invalid version specifier. Use c[hash], v[tag], \
or b[branch]"
      ;;
  esac
}

# Setup or update repository
setup_repository() {
  if [ ! -d "$REPOSITORY_DIR/.git" ]; then
    log "Repository not found, cloning..."
    mkdir -p "$(dirname "$REPOSITORY_DIR")" 2>/dev/null
    if ! git clone "$REPOSITORY_URL" "$REPOSITORY_DIR" \
>> "$LOG_FILE" 2>&1; then
      error_exit "Failed to clone repository"
    fi
    log "Repository cloned successfully"
  fi

  cd "$REPOSITORY_DIR" || error_exit "Failed to enter repository \
directory"

  # Fetch latest from remote
  log "Fetching from remote..."
  if ! git fetch --all --tags --prune >> "$LOG_FILE" 2>&1; then
    error_exit "Failed to fetch from remote"
  fi
  log "Fetch completed"
}

# Resolve version specifier to commit hash
resolve_version_to_commit() {
  cd "$REPOSITORY_DIR" || error_exit "Failed to enter repository \
directory"

  log "Resolving version: $VERSION_TYPE=$VERSION_VALUE"
  case "$VERSION_TYPE" in
    commit)
      COMMIT_HASH="$VERSION_VALUE"
      if ! git rev-parse --verify "${COMMIT_HASH}^{commit}" \
>> "$LOG_FILE" 2>&1; then
        error_exit "Invalid commit hash: $COMMIT_HASH"
      fi
      ;;
    tag)
      if ! COMMIT_HASH=$(git rev-parse --verify \
"refs/tags/${VERSION_VALUE}^{commit}" 2>>"$LOG_FILE"); then
        error_exit "Tag not found: $VERSION_VALUE"
      fi
      ;;
    branch)
      if ! COMMIT_HASH=$(git rev-parse --verify \
"origin/${VERSION_VALUE}^{commit}" 2>>"$LOG_FILE"); then
        error_exit "Branch not found: $VERSION_VALUE"
      fi
      ;;
  esac
  log "Resolved to commit: $COMMIT_HASH"

  # Convert to short hash (8 characters)
  COMMIT_HASH_SHORT=$(git rev-parse --short=8 "$COMMIT_HASH" 2>>"$LOG_FILE")
  log "Short hash: $COMMIT_HASH_SHORT"
}

# Get tag for commit if it exists
get_tag_for_commit() {
  cd "$REPOSITORY_DIR" || error_exit "Failed to enter repository \
directory"

  # Get all tags pointing to this commit
  local tags
  tags=$(git tag --points-at "$COMMIT_HASH" 2>/dev/null)

  if [ -n "$tags" ]; then
    # Find shortest tag(s), then pick first alphabetically
    echo "$tags" | awk '
      BEGIN { min_len = 999999 }
      {
        len = length($0)
        if (len < min_len) {
          min_len = len
          shortest = $0
        } else if (len == min_len && $0 < shortest) {
          shortest = $0
        }
      }
      END { if (shortest) print shortest }
    '
  fi
}

# Construct binary name
get_binary_name() {
  local version_identifier
  local tag
  tag=$(get_tag_for_commit)

  if [ -n "$tag" ]; then
    version_identifier="$tag"
  else
    version_identifier="$COMMIT_HASH_SHORT"
  fi

  local build_abbrev
  build_abbrev=$(get_build_type_abbrev)

  echo "mystran-${version_identifier}-${build_abbrev}"
}

# Clean repository state completely
clean_repository() {
  cd "$REPOSITORY_DIR" || error_exit "Failed to enter repository \
directory"

  log "Cleaning repository state..."

  # Clean and reset submodules first
  log "Cleaning submodules..."
  git submodule foreach --recursive git clean -fdx >> "$LOG_FILE" 2>&1
  git submodule foreach --recursive git reset --hard >> "$LOG_FILE" \
2>&1

  # Clean all files including gitignored ones
  if ! git clean -fdx >> "$LOG_FILE" 2>&1; then
    error_exit "Failed to clean repository"
  fi

  # Reset any changes
  if ! git reset --hard >> "$LOG_FILE" 2>&1; then
    error_exit "Failed to reset repository"
  fi
  log "Repository cleaned"
}

# Build mystran
build_mystran() {
  local binary_name="$1"
  local binary_path="${BINARIES_DIRECTORY}/${binary_name}"

  # Check if binary already exists
  if [ -f "$binary_path" ]; then
    log "Binary already exists: $binary_path"
    echo "$binary_path"
    return 0
  fi

  log "Building binary: $binary_name"
  cd "$REPOSITORY_DIR" || error_exit "Failed to enter repository \
directory"

  # Clean repository state
  clean_repository

  # Checkout the commit
  log "Checking out commit: $COMMIT_HASH"
  if ! git checkout "$COMMIT_HASH" >> "$LOG_FILE" 2>&1; then
    error_exit "Failed to checkout commit: $COMMIT_HASH"
  fi

  # Initialize and update submodules
  log "Initializing submodules..."
  if ! git submodule update --init --recursive >> "$LOG_FILE" 2>&1
  then
    error_exit "Failed to initialize submodules"
  fi
  log "Submodules initialized"

  # Configure
  log "Running configure: $CONFIGURE_COMMAND"
  if ! eval "$CONFIGURE_COMMAND" >> "$LOG_FILE" 2>&1; then
    error_exit "Configuration failed"
  fi
  log "Configuration completed"

  # Build
  log "Running build: $BUILD_COMMAND"
  if ! eval "$BUILD_COMMAND" >> "$LOG_FILE" 2>&1; then
    error_exit "Build failed"
  fi
  log "Build completed"

  # Check if binary was created
  if [ ! -f "${REPOSITORY_DIR}/Binaries/mystran" ]; then
    error_exit "Build completed but binary not found"
  fi

  # Copy to binaries directory
  mkdir -p "$BINARIES_DIRECTORY" 2>/dev/null
  if ! cp "${REPOSITORY_DIR}/Binaries/mystran" "$binary_path" \
>> "$LOG_FILE" 2>&1; then
    error_exit "Failed to copy binary to destination"
  fi
  log "Binary saved to: $binary_path"

  echo "$binary_path"
}

# Main execution
main() {
  # Save original working directory for running mystran
  local original_dir
  original_dir="$(pwd)"

  log_session_start "$@"
  parse_arguments "$@"
  setup_repository
  resolve_version_to_commit
  local binary_name
  binary_name=$(get_binary_name)
  log "Binary name: $binary_name"
  local binary_path
  binary_path=$(build_mystran "$binary_name")

  if [ -n "$INPUT_FILE" ]; then
    # Run mode - execute binary with input file
    log "Executing: $binary_path $INPUT_FILE"
    log_session_end "SUCCESS"
    cd "$original_dir" || error_exit "Failed to return to original \
directory"
    exec "$binary_path" "$INPUT_FILE"
  else
    # Print mode - output binary path
    log "Returning binary path: $binary_path"
    log_session_end "SUCCESS"
    echo "$binary_path"
  fi
}

main "$@"
